# ── Firebase (côté client) ────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Stripe (côté client — clé publique uniquement) ────────────────────────────
# Price IDs à créer dans Stripe Dashboard > Produits > Tarifs
VITE_STRIPE_PRICE_BASIC=price_...
VITE_STRIPE_PRICE_GUIDED=price_...
VITE_STRIPE_PRICE_PREMIUM=price_...

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173

# ── Firebase Cloud Functions — variables à définir côté serveur ──────────────
# Ces variables ne vont PAS dans ce fichier .env (elles sont dans functions/.env)
# Voir functions/.env.example pour les configurer :
#   STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, APP_URL
