rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    function hasActiveSubscription() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('subscriptionStatus', '') in ['active', 'trialing', 'paused'];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && (!request.resource.data.keys().hasAll(['role']) || request.resource.data.role != 'admin');
      allow update: if isAdmin() || (isOwner(userId) && (!request.resource.data.keys().hasAll(['role']) || request.resource.data.role == resource.data.role));

      match /progress/{moduleId} {
        allow read, create, update: if isOwner(userId) || isAdmin();
      }
    }

    match /modules/{moduleId} {
      // Contenu réservé aux abonnés actifs (active / trialing) et aux admins
      allow read: if hasActiveSubscription() || isAdmin();
      allow write: if isAdmin();
    }

    // Sous-collection /users/{userId}/deliverables/{moduleId}
    match /users/{userId}/deliverables/{moduleId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isOwner(userId);
      // L'utilisateur ne peut modifier que ses propres champs — pas status ni feedback (réservés à l'admin)
      allow update: if isAdmin() || (
        isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'feedback'])
      );
    }

    // Règle collectionGroup pour les queries admin cross-users
    match /{path=**}/deliverables/{moduleId} {
      allow read: if isAdmin();
    }

    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
    }
  }
}
