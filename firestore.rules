rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================
    // FONCTIONS HELPER
    // ========================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function hasActiveSubscription() {
      // Pour l'instant, on vérifie juste si le champ existe et n'est pas 'canceled'/'unpaid'
      // À adapter selon la logique exacte de Stripe
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isAuthenticated() && 
             user.data.subscriptionStatus in ['active', 'trialing'];
    }

    // ========================================
    // COLLECTION: users
    // ========================================
    
    function isNotChangingSensitiveFields() {
      // Vérifie que les champs sensibles ne sont pas modifiés
      return request.resource.data.role == resource.data.role &&
             request.resource.data.plan == resource.data.plan &&
             request.resource.data.subscriptionStatus == resource.data.subscriptionStatus;
    }

    // ========================================
    // COLLECTION: users
    // ========================================
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId); // Lors du signup
      allow update: if isAdmin() || (isOwner(userId) && isNotChangingSensitiveFields()); 
      
      // Progression des modules
      match /progress/{moduleId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId); // L'utilisateur peut créer sa progression
        allow update: if isOwner(userId) || isAdmin(); // L'utilisateur peut mettre à jour sa progression
      }
      
      // Livrables de l'utilisateur
      match /deliverables/{deliverableId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId); // L'utilisateur peut soumettre des livrables
        allow update: if isAdmin(); // Seul l'admin peut mettre à jour (feedback)
      }
    }
    
    // ========================================
    // COLLECTION: modules
    // ========================================
    
    match /modules/{moduleId} {
      // Lecture publique ou restreinte aux abonnés ? 
      // Pour l'instant : authentifié requis. 
      // Plus tard : hasActiveSubscription()
      allow read: if isAuthenticated(); 
      allow write: if isAdmin();
    }
    
    // ========================================
    // COLLECTION: deliverables (collection globale)
    // ========================================
    
    match /deliverables/{deliverableId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (
        isAuthenticated() && resource.data.userId == request.auth.uid
      );
    }
    
    // ========================================
    // TRACES & ADMIN
    // ========================================
    
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
